{
  "name": "d3-heatmap2",
  "version": "1.1.1",
  "description": "",
  "keywords": [
    "d3",
    "d3-module"
  ],
  "main": "./dist/d3-heatmap2.umd.js",
  "module": "./dist/d3-heatmap2.es.js",
  "exports": {
    ".": {
      "import": "./dist/d3-heatmap2.es.js",
      "require": "./dist/d3-heatmap2.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "directories": {
    "example": "examples"
  },
  "homepage": "https://github.com/spiermar/d3-heatmap2",
  "scripts": {
    "build": "vite build --config vite.config.mjs && vite build --config vite.config.min.mjs",
    "dev": "vite",
    "lint": "eslint src lib",
    "test": "tape 'test/**/*-test.js'",
    "prepare": "npm run test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/spiermar/d3-heatmap2"
  },
  "author": "Martin Spier <spiermar@gmail.com>",
  "license": "Apache-2.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "tape": "^4.9.1",
    "uglify-es": "^3.3.9",
    "vite": "^7.3.1",
    "vite-plugin-lib-inject-css": "^2.2.2"
  },
  "dependencies": {
    "d3-array": "^1.2.4",
    "d3-axis": "^1.0.12",
    "d3-format": "^1.3.2",
    "d3-scale": "^2.1.2",
    "d3-selection": "^1.3.2",
    "yargs": "^11.0.0"
  }
}
